{
  "name": "monad-rgp-contracts",
  "version": "1.0.0",
  "description": "Soulbound Reputational Graph Protocol smart contracts for Monad",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:monad": "hardhat run scripts/deploy.ts --network monad",
    "lint": "solhint 'src/**/*.sol'",
    "format": "prettier --write 'src/**/*.sol' 'test/**/*.ts'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@types/chai": "^4.3.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.7",
    "ethers": "^6.9.0",
    "hardhat": "^2.19.0",
    "prettier": "^3.0.0",
    "prettier-plugin-solidity": "^1.3.0",
    "solhint": "^4.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
