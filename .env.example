# ─── Blockchain ──────────────────────────────────────────────────────────────
# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com
# Signer private key path (NEVER commit real keys)
SOLANA_KEYPAIR_PATH=

# ─── Solana Program IDs ───────────────────────────────────────────────────────
IDENTITY_PROGRAM_ID=
SBT_PROGRAM_ID=
ATTESTATION_PROGRAM_ID=
RGP_PROGRAM_ID=

# ─── Indexer ──────────────────────────────────────────────────────────────────
START_SLOT=0
COMMITMENT=confirmed

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=rgp
POSTGRES_PASSWORD=rgp
POSTGRES_DB=rgp
DATABASE_URL=postgresql://rgp:rgp@localhost:5432/rgp

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── Graph Engine ─────────────────────────────────────────────────────────────
RUST_LOG=info
