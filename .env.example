# ─── Blockchain ──────────────────────────────────────────────────────────────
# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# Signer private key path (NEVER commit real keys)
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# ─── Solana Program IDs ───────────────────────────────────────────────────────
# Before the first devnet deploy, leave these empty. After deploy, set all four
# values to the deployed RGP program ID; the current indexer has separate
# listeners for the identity, SBT, and attestation log families emitted by the
# same program.
IDENTITY_PROGRAM_ID=
SBT_PROGRAM_ID=
ATTESTATION_PROGRAM_ID=
RGP_PROGRAM_ID=
VITE_RGP_PROGRAM_ID=

# ─── Indexer ──────────────────────────────────────────────────────────────────
START_SLOT=0
COMMITMENT=confirmed

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=rgp
POSTGRES_PASSWORD=rgp
POSTGRES_DB=rgp
DATABASE_URL=postgresql://rgp:rgp@localhost:5432/rgp

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:3001
JWT_SECRET=replace-with-a-32-byte-local-secret-before-sharing

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_SOLANA_CLUSTER=devnet

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change-me-strong-password

# ─── Graph Engine ─────────────────────────────────────────────────────────────
RUST_LOG=info
